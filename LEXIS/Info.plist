	<!--
	  PARTIAL Info.plist — only the keys Xcode's GENERATE_INFOPLIST_FILE can't
	  produce. Everything else (launch screen, scene manifest, orientations,
	  display name, encryption + ATT strings) still comes from the
	  INFOPLIST_KEY_* build settings in project.yml and is MERGED into this file
	  at build time. Don't duplicate those keys here.

	  GADApplicationIdentifier is required by the Google Mobile Ads SDK — it
	  throws at MobileAds.start() if absent. It is NOT settable via
	  INFOPLIST_KEY_ (Xcode only passes through keys it knows), which is why
	  this file exists. The value comes from the GAD_APPLICATION_IDENTIFIER
	  build setting in project.yml so it stays in one place.
	-->
	<key>GADApplicationIdentifier</key>
	<string>$(GAD_APPLICATION_IDENTIFIER)</string>

